{
  "manifest_version": 3,
  "name": "COR3 Helper",
  "version": "3.0",
  "description": "Monitor markets, expeditions, daily ops, and get timer alerts for cor3.gg.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://cor3.gg/*",
    "https://svc-corie.cor3.gg/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cor3.gg/*"],
      "js": ["content-early.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://cor3.gg/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "COR3 Helper"
  },
  "web_accessible_resources": [
    {
      "resources": ["ws-interceptor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}